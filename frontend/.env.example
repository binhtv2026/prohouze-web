# ProHouzing — Production Environment Variables
# Copy file này thành .env.local (không commit lên Git)
# Điền đầy đủ trước khi deploy lên Vercel

# ─── Backend API ──────────────────────────────────────────────────────────────
REACT_APP_BACKEND_URL=https://api.prohouzing.com
REACT_APP_ENV=production

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Lấy tại: app.supabase.com > Project Settings > API
REACT_APP_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Firebase (Push Notifications) ───────────────────────────────────────────
# Lấy tại: console.firebase.google.com > Project Settings > Web App
REACT_APP_FIREBASE_API_KEY=AIzaSy...
REACT_APP_FIREBASE_AUTH_DOMAIN=prohouzing-prod.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=prohouzing-prod
REACT_APP_FIREBASE_STORAGE_BUCKET=prohouzing-prod.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abcdef
# Web push certificate key từ Firebase Console > Cloud Messaging > Web Push Certificates
REACT_APP_FIREBASE_VAPID_KEY=BF...

# ─── Analytics ────────────────────────────────────────────────────────────────
REACT_APP_ANALYTICS_ENABLED=true
# PostHog: app.posthog.com > Project Settings > API Key
REACT_APP_POSTHOG_KEY=phc_...
REACT_APP_POSTHOG_HOST=https://app.posthog.com

# ─── Error Monitoring ─────────────────────────────────────────────────────────
# Sentry: app.sentry.io > Settings > Projects > DSN
REACT_APP_SENTRY_DSN=https://xxxx@oxxxxxx.ingest.sentry.io/xxxxxxx

# ─── Build ────────────────────────────────────────────────────────────────────
GENERATE_SOURCEMAP=false
DISABLE_ESLINT_PLUGIN=false
